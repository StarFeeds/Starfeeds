# Database
DATABASE_URL=postgresql+asyncpg://starfeeds:starfeeds@localhost:5432/starfeeds

# JWT
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Public frontend URL (used for links inside emails)
FRONTEND_URL=http://localhost:3000

# Email / SMTP — OPTIONAL. Leave SMTP_HOST blank to disable (sends are skipped,
# signup still works). Works with any SMTP provider (Resend, Gmail, SendGrid...).
# Resend example:  SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USER=resend  SMTP_PASSWORD=<api key>
# Gmail example:   SMTP_HOST=smtp.gmail.com   SMTP_PORT=587  SMTP_USER=<you@gmail.com>  SMTP_PASSWORD=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=StarFeeds
