# Base URL of the StarFeeds API (no trailing slash, no /api/v1).
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (set this in the Vercel dashboard -> Project -> Settings -> Environment Variables):
# NEXT_PUBLIC_API_URL=https://starfeeds-api.onrender.com
#
# Note: the realtime WebSocket URL is derived automatically (https -> wss).
